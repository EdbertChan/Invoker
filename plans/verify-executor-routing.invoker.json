{
  "allowGraphMutation": true,
  "defaultBranch": "master",
  "executorRoutingRules": [
    {
      "pattern": "verify-routing-ok",
      "executorType": "worktree",
      "poolId": "dummy-pool"
    }
  ],
  "executionPools": {
    "dummy-pool": {
      "members": [
        {
          "type": "worktree",
          "id": "local"
        }
      ]
    }
  },
  "remoteTargets": {
    "dummy-target": {
      "host": "localhost",
      "user": "nobody",
      "sshKeyPath": "/dev/null"
    }
  }
}
